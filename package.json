{
  "name": "genotype-scout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "node --max-old-space-size=6144 node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "cap:build": "CAPACITOR=true vite build && npx cap sync",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "sync-pgx": "tsx src/scripts/cannibalizeOpenPGx.ts",
    "sync-graf": "tsx src/scripts/fetchGrafWeights.ts",
    "sync-pca": "tsx src/scripts/sync-hgdp-pca.ts",
    "sync-admixture": "tsx scripts/parse-open-admixture.ts",
    "sync-all": "tsx src/scripts/sync-scout.ts && npm run build",
    "build-health": "tsx scripts/build-master-health.ts",
    "build-ancient": "tsx scripts/build-master-ancient.ts",
    "enrich-markers": "tsx scripts/enrich-marker-metadata.ts",
    "test": "vitest run",
    "validate:data": "tsx src/utils/dataValidator.ts",
    "validate:json": "node scripts/validate-data-json.mjs",
    "prebuild": "node scripts/validate-data-json.mjs",
    "build:yphylo": "tsx scripts/build-y-phylotree.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-window": "^1.8.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "dotenv": "^17.2.3",
    "firebase": "^12.13.0",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "ml-pca": "^4.1.1",
    "motion": "^12.23.24",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.4"
  }
}
